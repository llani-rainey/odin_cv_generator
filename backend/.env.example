# Copy this file to .env and fill in your values
# Never commit .env — it's listed in .gitignore

# Django secret key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to True for local development only — always False in production
DEBUG=True

# PostgreSQL database — create a local DB first: createdb cv_db
DB_NAME=cv_db
DB_USER=your_mac_username
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis — install and start Redis locally: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379

# Google OAuth credentials — create at console.cloud.google.com
# After setting these up, add a Google Social Application via Django admin (/admin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
